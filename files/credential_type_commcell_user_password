###Input Configuration####

fields:
  - id: hdps_auth_method
    type: string
    label: Auth Method
    default: user_password

  - id: hdps_commserve_hostname
    type: string
    label: CommServe Hostname
    secret: false

  - id: hdps_commcell_user
    type: string
    label: CommCell Username
    secret: false

  - id: hdps_commcell_password
    type: string
    label: CommCell Password
    secret: true

required:
  - hdps_auth_method
  - hdps_commserve_hostname
  - hdps_commcell_user
  - hdps_commcell_password

####Injector Configuration####

extra_vars:
  hdps_auth_method: '{{ hdps_auth_method }}'
  hdps_commserve_hostname: '{{ hdps_commserve_hostname }}'
  hdps_commcell_user: '{{ hdps_commcell_user }}'
  hdps_commcell_password: '{{ hdps_commcell_password }}'



