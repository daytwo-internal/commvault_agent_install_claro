fields:
  - id: hdps_auth_method
    type: string
    label: Auth Method
    default: authcode

  - id: hdps_commserve_hostname
    type: string
    label: CommServe Hostname
    secret: false

  - id: hdps_authcode
    type: string
    label: AuthCode
    secret: true

required:
  - hdps_auth_method
  - hdps_commserve_hostname
  - hdps_authcode


######################Injector Configuration####

extra_vars:
  hdps_auth_method: '{{ hdps_auth_method }}'
  hdps_commserve_hostname: '{{ hdps_commserve_hostname }}'
  hdps_authcode: '{{ hdps_authcode }}'

  